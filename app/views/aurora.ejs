<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
  <title>Aurora · Local Photo Viewer</title>
  <!-- PWA / add-to-home-screen -->
  <link rel="manifest" href="/aurora-manifest.json">
  <meta name="theme-color" content="#06060c">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Aurora">
  <link rel="apple-touch-icon" href="/aurora-icon-180.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --void: #06060c;
      --panel: rgba(255,255,255,0.05);
      --panel-hover: rgba(255,255,255,0.08);
      --border: rgba(255,255,255,0.10);
      --border-strong: rgba(255,255,255,0.18);
      --text: rgba(255,255,255,0.92);
      --text-muted: rgba(255,255,255,0.45);
      --text-faint: rgba(255,255,255,0.25);
      --accent: #a78bfa;
      --accent-sky: #7dd3fc;
      --accent-orchid: #f0abfc;
      --accent-glow: rgba(167,139,250,0.3);
      --radius: 16px;
      --radius-sm: 10px;
      --sidebar-w: 220px;
      --font-mono: 'JetBrains Mono', monospace;
    }

    html, body { height: 100%; overflow: hidden; }
    /* Set the background on <html> too so any browser-chrome bleed on iOS PWAs
       (safe-area gaps around the notch / home indicator) reads as the app
       colour, not white. Without this the standalone PWA can flash white on
       load and shows visible seams around the status bar. */
    html { background: var(--void); }
    body {
      background: var(--void);
      color: var(--text);
      font-family: 'Space Grotesk', sans-serif;
      font-size: 14px;
    }

    /* Aurora animated backdrop */
    .aurora-bg {
      position: fixed; inset: 0; z-index: 0; overflow: hidden; pointer-events: none;
    }
    .aurora-bg span {
      position: absolute;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.18;
      mix-blend-mode: screen;
      animation: drift linear infinite;
    }
    .aurora-bg span:nth-child(1) {
      width: 700px; height: 500px;
      background: var(--accent);
      top: -100px; left: -150px;
      animation-duration: 28s;
    }
    .aurora-bg span:nth-child(2) {
      width: 600px; height: 600px;
      background: var(--accent-sky);
      bottom: -200px; right: -100px;
      animation-duration: 36s; animation-delay: -12s;
    }
    .aurora-bg span:nth-child(3) {
      width: 500px; height: 400px;
      background: var(--accent-orchid);
      top: 40%; left: 40%;
      animation-duration: 44s; animation-delay: -20s;
    }
    @keyframes drift {
      0%   { transform: translate(0,0) scale(1); }
      33%  { transform: translate(60px,-40px) scale(1.05); }
      66%  { transform: translate(-40px, 50px) scale(0.97); }
      100% { transform: translate(0,0) scale(1); }
    }

    /* Layout */
    .app {
      position: relative; z-index: 1;
      display: flex; width: 100vw;
      /* Use dvh so iOS PWA / mobile Safari don't leave a slice of unused
         viewport at top/bottom when the URL bar or system chrome shifts.
         100vh is a fixed value on iOS and doesn't track the visible viewport
         once the shell is in standalone mode. */
      height: 100vh;   /* fallback */
      height: 100dvh;
    }

    /* Sidebar */
    .sidebar {
      width: var(--sidebar-w);
      flex-shrink: 0;
      display: flex; flex-direction: column;
      background: rgba(6,6,12,0.7);
      border-right: 1px solid var(--border);
      backdrop-filter: blur(20px);
      padding: 0;
      position: relative;
      transition: width 0.2s ease;
    }
    .sidebar-logo {
      padding: 24px 20px 18px;
      display: flex; align-items: center; gap: 10px;
      border-bottom: 1px solid var(--border);
    }
    /* Sidebar collapse toggle — floats on the right edge and rotates 180° when collapsed. */
    .sidebar-collapse {
      position: absolute; top: 22px; right: -12px; z-index: 10;
      width: 24px; height: 24px; border-radius: 50%;
      background: rgba(14,14,24,0.98); border: 1px solid var(--border-strong);
      color: var(--text-muted); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-family: inherit; font-size: 12px; line-height: 1;
      transition: color 0.15s, transform 0.2s ease;
      padding: 0;
    }
    .sidebar-collapse:hover { color: var(--text); }
    body.sidebar-collapsed {
      --sidebar-w: 68px;
    }
    body.sidebar-collapsed .sidebar-collapse { transform: rotate(180deg); }
    body.sidebar-collapsed .sidebar-logo { padding: 22px 0 18px; justify-content: center; }
    body.sidebar-collapsed .sidebar-logo > div:not(.logo-icon) { display: none; }
    body.sidebar-collapsed .sidebar-nav { padding: 12px 8px; }
    body.sidebar-collapsed .nav-item { justify-content: center; padding: 10px 6px; gap: 0; overflow: hidden; }
    /* When collapsed, show icons only — labels and badges disappear and any
       bare text nodes are zeroed out via font-size:0 so no "L" or "S" leaks
       through next to the icon. The icon itself restores its font-size. */
    body.sidebar-collapsed .nav-item { font-size: 0; }
    body.sidebar-collapsed .nav-item .nav-icon { font-size: 15px; }
    body.sidebar-collapsed .nav-item .nav-label,
    body.sidebar-collapsed .nav-item .nav-badge { display: none; }
    body.sidebar-collapsed .nav-section { display: none; }
    body.sidebar-collapsed .sidebar-stats { display: none; }
    body.sidebar-collapsed .nav-item[data-tip]:hover::after {
      content: attr(data-tip);
      position: absolute; left: calc(100% + 8px); top: 50%; transform: translateY(-50%);
      background: rgba(14,14,24,0.98); border: 1px solid var(--border-strong);
      color: var(--text); padding: 5px 10px; border-radius: 6px;
      font-size: 12px; font-family: inherit; white-space: nowrap; pointer-events: none;
      z-index: 200;
    }
    .logo-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, var(--accent), var(--accent-sky));
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }
    .logo-text { font-size: 18px; font-weight: 600; letter-spacing: -0.3px; }
    .logo-sub { font-size: 10px; font-family: var(--font-mono); color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase; }

    .sidebar-nav { padding: 12px 10px; flex: 1; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 12px; border-radius: var(--radius-sm);
      cursor: pointer; color: var(--text-muted);
      font-weight: 500; font-size: 13.5px;
      transition: all 0.15s; user-select: none;
      position: relative;
    }
    .nav-item:hover { background: var(--panel); color: var(--text); }
    .nav-item.active {
      background: rgba(167,139,250,0.12);
      color: var(--accent);
    }
    .nav-item.active::before {
      content: ''; position: absolute; left: 0; top: 20%; bottom: 20%;
      width: 2px; border-radius: 2px; background: var(--accent);
      box-shadow: 0 0 8px var(--accent-glow);
    }
    .nav-icon { width: 18px; text-align: center; font-size: 15px; flex-shrink: 0; }
    .nav-label { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .nav-badge {
      margin-left: auto; font-family: var(--font-mono);
      font-size: 10px; color: var(--text-faint); letter-spacing: 0.5px;
    }
    .nav-section { padding: 14px 12px 6px; font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-faint); font-family: var(--font-mono); }

    .sidebar-stats {
      padding: 14px 14px 18px;
      border-top: 1px solid var(--border);
    }
    .stat-row { display: flex; justify-content: space-between; padding: 3px 0; }
    .stat-label { font-size: 11px; color: var(--text-muted); }
    .stat-val { font-family: var(--font-mono); font-size: 11px; color: var(--text); }

    /* Main content */
    .main {
      flex: 1; display: flex; flex-direction: column;
      overflow: hidden; min-width: 0;
    }

    /* Top bar */
    .topbar {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      background: rgba(6,6,12,0.5);
      backdrop-filter: blur(10px);
      flex-shrink: 0;
    }
    .topbar-title { font-size: 16px; font-weight: 600; margin-right: 4px; }
    .topbar-count { font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); }
    .topbar-spacer { flex: 1; }

    .tab-group { display: flex; gap: 2px; background: var(--panel); border-radius: var(--radius-sm); padding: 3px; }
    .tab-btn {
      padding: 5px 14px; border-radius: 8px; border: none;
      background: none; color: var(--text-muted); font-family: inherit;
      font-size: 12.5px; cursor: pointer; font-weight: 500; transition: all 0.15s;
    }
    .tab-btn.active { background: rgba(255,255,255,0.08); color: var(--text); }
    .tab-btn:hover:not(.active) { color: var(--text); }

    .icon-btn {
      width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--border);
      background: var(--panel); color: var(--text-muted); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; transition: all 0.15s;
    }
    .icon-btn:hover { background: var(--panel-hover); color: var(--text); border-color: var(--border-strong); }

    /* Screens */
    .screen { display: none; flex: 1; overflow: hidden; flex-direction: column; }
    .screen.active { display: flex; }

    /* ── LIBRARY SCREEN ── */
    .library-controls {
      padding: 14px 20px; border-bottom: 1px solid var(--border);
      background: rgba(6,6,12,0.3); flex-shrink: 0;
    }
    .slider-row { display: flex; align-items: center; gap: 16px; margin-bottom: 10px; }
    .slider-label { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); min-width: 80px; }
    .slider-value { font-family: var(--font-mono); font-size: 11px; color: var(--accent); min-width: 100px; text-align: right; }
    .range-wrap { flex: 1; position: relative; height: 26px; display: flex; align-items: center; }
    input[type=range] {
      -webkit-appearance: none; width: 100%; height: 5px;
      background: var(--border); border-radius: 3px; outline: none; cursor: pointer;
    }
    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%;
      background: var(--accent); cursor: pointer;
      box-shadow: 0 0 0 3px rgba(167,139,250,0.2), 0 0 10px var(--accent-glow);
      transition: box-shadow 0.15s;
    }
    input[type=range]::-webkit-slider-thumb:hover {
      box-shadow: 0 0 0 6px rgba(167,139,250,0.25), 0 0 14px var(--accent-glow);
    }
    input[type=range]::-moz-range-thumb {
      width: 18px; height: 18px; border-radius: 50%; border: none;
      background: var(--accent); cursor: pointer;
      box-shadow: 0 0 0 3px rgba(167,139,250,0.2);
    }
    input[type=range]::-moz-range-track {
      height: 5px; background: var(--border); border-radius: 3px;
    }

    /* Histogram */
    .histogram { flex: 1; height: 28px; display: flex; align-items: flex-end; gap: 1px; }
    .hist-bar {
      flex: 1; border-radius: 2px 2px 0 0; min-height: 2px;
      background: rgba(167,139,250,0.25); transition: background 0.15s;
    }
    .hist-bar.in-range { background: rgba(167,139,250,0.6); }

    .grid-density-row { display: flex; align-items: center; gap: 12px; }
    .density-label { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
    #densitySlider { width: 140px; }

    /* Photo grid */
    .photo-grid-wrap { flex: 1; overflow-y: auto; padding: 16px 20px; position: relative; }
    /* Virtualized grid: tiles are absolutely positioned inside a sized spacer */
    #photoGrid { position: relative; width: 100%; }
    #photoGrid .photo-tile { position: absolute; }
    /* Inline month/year break headers in the virtualized grid */
    #photoGrid .month-break {
      position: absolute; left: 0; right: 0;
      display: flex; align-items: flex-end; gap: 10px;
      padding-bottom: 8px; pointer-events: none;
    }
    #photoGrid .mb-label { font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: var(--text); letter-spacing: 0.3px; }
    #photoGrid .mb-count { font-family: var(--font-mono); font-size: 11px; color: var(--text-faint); padding-bottom: 2px; }
    .floating-month {
      position: sticky; top: 0; z-index: 5; align-self: flex-start;
      display: inline-block; pointer-events: none;
      font-family: var(--font-mono); font-size: 11px; letter-spacing: 1px;
      text-transform: uppercase; color: var(--text);
      background: rgba(6,6,12,0.82); border: 1px solid var(--border);
      border-radius: 20px; padding: 5px 14px; margin-bottom: 8px;
      backdrop-filter: blur(10px); opacity: 0; transition: opacity 0.2s;
    }
    .floating-month.show { opacity: 1; }
    .month-group { margin-bottom: 24px; }
    .month-header {
      font-family: var(--font-mono); font-size: 11px; letter-spacing: 1px;
      text-transform: uppercase; color: var(--text-muted);
      margin-bottom: 10px; display: flex; align-items: center; gap: 8px;
    }
    .month-header::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .photo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(var(--tile-size, 180px), 1fr));
      gap: 4px;
    }
    /* Virtualized search grid: only on-screen tiles exist (absolutely positioned),
       so scrolling thousands of results stays smooth on mobile. */
    #searchGrid.virtual { display: block; position: relative; }
    #searchGrid.virtual .photo-tile { position: absolute; }
    .photo-tile {
      aspect-ratio: 1; border-radius: 6px; overflow: hidden;
      background: rgba(255,255,255,0.04); cursor: pointer; position: relative;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .photo-tile:hover { transform: scale(1.02); z-index: 2; box-shadow: 0 8px 24px rgba(0,0,0,0.6); }
    .photo-tile img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .photo-tile .tile-overlay {
      position: absolute; inset: 0; opacity: 0; transition: opacity 0.15s;
      background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
      display: flex; align-items: flex-end; padding: 8px;
    }
    .photo-tile:hover .tile-overlay { opacity: 1; }
    .tile-date { font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.7); }
    .tile-fav { position: absolute; top: 6px; right: 6px; font-size: 13px; opacity: 0; transition: opacity 0.15s; cursor: pointer; }
    .photo-tile:hover .tile-fav, .photo-tile.faved .tile-fav { opacity: 1; }
    .photo-tile.faved .tile-fav { color: #f59e0b; }
    .tile-video-badge {
      position: absolute; top: 6px; left: 6px;
      background: rgba(0,0,0,0.6); border-radius: 4px; padding: 2px 5px;
      font-family: var(--font-mono); font-size: 9px; color: var(--accent-sky);
    }
    .tile-live-badge {
      position: absolute; top: 6px; left: 6px;
      background: rgba(0,0,0,0.55); border-radius: 4px; padding: 2px 5px;
      font-family: var(--font-mono); font-size: 8px; letter-spacing: 0.5px;
      color: #fff; display: flex; align-items: center; gap: 3px;
    }
    .tile-live-badge::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      border: 1.5px solid #fff; box-sizing: border-box;
    }
    /* ── Multi-select ── */
    .tile-check {
      position: absolute; top: 6px; left: 6px; width: 22px; height: 22px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.9); background: rgba(0,0,0,0.35);
      display: none; align-items: center; justify-content: center; z-index: 4;
      color: #fff; font-size: 13px; line-height: 1;
    }
    body.select-mode .photo-tile .tile-check { display: flex; }
    .photo-tile.selected .tile-check { background: var(--accent); border-color: #fff; }
    .photo-tile.selected .tile-check::after { content: '✓'; }
    .photo-tile.selected { outline: 3px solid var(--accent); outline-offset: -3px; }
    .photo-tile.selected img { opacity: 0.82; }
    /* In select mode, nudge the video/live badge right so it clears the checkbox,
       and don't scale tiles on hover (it fights tap-to-select). */
    body.select-mode .photo-tile .tile-video-badge,
    body.select-mode .photo-tile .tile-live-badge { left: 34px; }
    body.select-mode .photo-tile:hover { transform: none; box-shadow: none; }
    body.select-mode .photo-tile .tile-fav { display: none; }
    /* In select mode a touch-drag on a tile should sweep-select, not scroll. */
    body.select-mode .photo-tile { touch-action: none; }

    .selection-bar {
      display: none; position: fixed; left: 50%; transform: translateX(-50%); bottom: 24px;
      z-index: 130; flex-direction: column; gap: 10px; max-width: 92vw;
      background: rgba(20,20,30,0.97); border: 1px solid var(--border-strong); border-radius: 14px;
      padding: 12px 14px; backdrop-filter: blur(20px); box-shadow: 0 14px 44px rgba(0,0,0,0.6);
    }
    body.select-mode .selection-bar { display: flex; }
    .sel-count { font-family: var(--font-mono); font-size: 12px; color: var(--accent); text-align: center; }
    .sel-main, .sel-entry { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; justify-content: center; }
    .sel-btn {
      padding: 7px 13px; border-radius: 8px; border: 1px solid var(--border);
      background: var(--panel); color: var(--text); font-family: inherit; font-size: 12.5px; cursor: pointer;
    }
    .sel-btn:hover { background: var(--panel-hover); }
    .sel-primary { background: var(--accent); border-color: var(--accent); color: #fff; }
    .sel-entry input {
      background: rgba(255,255,255,0.08); border: 1px solid var(--border); border-radius: 8px;
      color: var(--text); font-family: inherit; font-size: 13px; padding: 7px 10px; outline: none; min-width: 180px;
    }
    .sel-entry input:focus { border-color: var(--accent); }
    .sel-menu { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; max-width: 440px; }
    @media (max-width: 760px) {
      .selection-bar { left: 8px; right: 8px; transform: none; max-width: none; bottom: calc(60px + env(safe-area-inset-bottom)); }
    }

    .photo-tile .tile-skeleton {
      position: absolute; inset: 0;
      background: linear-gradient(90deg, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.07) 50%, rgba(255,255,255,0.03) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* Empty state */
    .empty-state {
      flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 16px; color: var(--text-muted);
    }
    .empty-icon { font-size: 48px; opacity: 0.3; }
    .empty-title { font-size: 18px; font-weight: 500; color: var(--text); }
    .empty-desc { font-size: 13px; text-align: center; max-width: 320px; line-height: 1.6; }
    .btn {
      padding: 10px 22px; border-radius: var(--radius-sm); border: none;
      background: linear-gradient(135deg, var(--accent), #8b5cf6);
      color: white; font-family: inherit; font-size: 13.5px; font-weight: 500;
      cursor: pointer; transition: opacity 0.15s, transform 0.15s;
      box-shadow: 0 4px 16px rgba(167,139,250,0.3);
    }
    .btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-ghost {
      background: var(--panel); color: var(--text);
      border: 1px solid var(--border); box-shadow: none;
    }
    .btn-ghost:hover { background: var(--panel-hover); }

    /* ── PLACES SCREEN ── */
    .places-layout { display: flex; flex: 1; overflow: hidden; }
    .map-area {
      flex: 1; position: relative; overflow: hidden;
      background: radial-gradient(ellipse at center, rgba(125,211,252,0.05) 0%, transparent 70%);
      display: flex; align-items: center; justify-content: center;
    }
    .map-placeholder {
      position: absolute; inset: 0;
      background: rgba(6,6,12,0.5);
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 8px; color: var(--text-muted);
    }
    .map-area { cursor: grab; touch-action: none; }
    .map-area.grabbing { cursor: grabbing; }
    .map-controls {
      position: absolute; top: 14px; right: 14px; z-index: 4;
      display: flex; flex-direction: column; gap: 6px;
    }
    .map-ctrl {
      width: 34px; height: 34px; border-radius: 9px;
      background: rgba(6,6,12,0.8); border: 1px solid var(--border);
      color: var(--text); font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      backdrop-filter: blur(10px); transition: background 0.15s; line-height: 1;
    }
    .map-ctrl:hover { background: rgba(255,255,255,0.14); border-color: var(--border-strong); }
    .map-hint {
      position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); z-index: 4;
      font-family: var(--font-mono); font-size: 10px; color: var(--text-faint);
      background: rgba(6,6,12,0.7); border: 1px solid var(--border);
      border-radius: 20px; padding: 4px 12px; pointer-events: none;
      white-space: nowrap;
    }
    .world-map { position: absolute; inset: 0; width: 100%; height: 100%; }
    .world-map path {
      fill: rgba(125,211,252,0.10);
      stroke: rgba(125,211,252,0.40);
      stroke-width: 0.8;
      vector-effect: non-scaling-stroke;
    }
    .place-pins { position: absolute; inset: 0; }
    .place-pin {
      position: absolute; transform: translate(-50%,-50%);
      cursor: pointer; transition: transform 0.2s;
    }
    .pin-label {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, calc(-50% - 22px));
      font-family: var(--font-mono); font-size: 10px; white-space: nowrap;
      color: var(--text); background: rgba(6,6,12,0.8);
      border: 1px solid var(--border); border-radius: 6px; padding: 2px 7px;
      opacity: 0; transition: opacity 0.15s; pointer-events: none;
    }
    .place-pin:hover .pin-label, .place-pin.active .pin-label { opacity: 1; }
    .place-pin:hover { transform: translate(-50%,-50%) scale(1.2); }
    .pin-dot {
      border-radius: 50%; background: var(--accent-sky);
      border: 2px solid rgba(255,255,255,0.3);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-mono); font-size: 9px; font-weight: 500;
      color: var(--void);
      box-shadow: 0 0 12px rgba(125,211,252,0.4);
      transition: all 0.15s;
    }
    .place-pin:hover .pin-dot, .place-pin.active .pin-dot {
      background: var(--accent); box-shadow: 0 0 16px var(--accent-glow);
    }
    /* Clusters (multiple places) get a halo ring so they read as a group */
    .place-pin.cluster .pin-dot {
      border-color: rgba(255,255,255,0.55);
      box-shadow: 0 0 0 4px rgba(125,211,252,0.18), 0 0 14px rgba(125,211,252,0.5);
    }
    /* When the map is zoomed in enough that only a few pins remain, show their
       place names permanently (single places only — clusters stay hover-only). */
    .place-pins.labels-on .place-pin:not(.cluster) .pin-label { opacity: 0.92; }

    /* Country-name labels (a quiet background layer beneath the pins) */
    .map-labels { position: absolute; inset: 0; pointer-events: none; z-index: 2; overflow: hidden; }
    .country-label {
      position: absolute; transform: translate(-50%, -50%);
      font-family: var(--font-mono); font-size: 11px; letter-spacing: 1.5px;
      text-transform: uppercase; font-weight: 500; white-space: nowrap;
      color: rgba(125,211,252,0.5); text-shadow: 0 1px 5px rgba(0,0,0,0.85);
    }

    .place-detail {
      width: 280px; border-left: 1px solid var(--border);
      background: rgba(6,6,12,0.8); backdrop-filter: blur(20px);
      display: flex; flex-direction: column; overflow: hidden;
    }
    .place-detail-header { padding: 16px; border-bottom: 1px solid var(--border); }
    .place-detail-name { font-size: 15px; font-weight: 600; }
    .place-detail-meta { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-top: 4px; }
    .place-detail-preview-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-faint); padding: 12px 12px 0; }
    .place-mini-grid { padding: 12px; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 3px; flex: 1; overflow-y: auto; align-content: start; min-width: 0; }
    .place-mini-tile {
      position: relative;
      /* Square tile keyed off the row's inline size. aspect-ratio alone was
         inconsistent on iOS Safari inside grid tracks — the tile would
         sometimes render at natural image height and overlap its neighbour.
         padding-top: 100% is universally supported and forces a square. */
      width: 100%;
      padding-top: 100%;
      border-radius: 4px; overflow: hidden;
      background: rgba(255,255,255,0.04); cursor: pointer;
    }
    .place-mini-tile img {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%; object-fit: cover;
    }

    /* ── SEARCH SCREEN ── */
    .search-layout { flex: 1; display: flex; overflow: hidden; }
    .search-sidebar {
      width: 240px; border-right: 1px solid var(--border);
      padding: 16px; overflow-y: auto;
      background: rgba(6,6,12,0.4);
    }
    .search-results { flex: 1; overflow-y: auto; padding: 16px 20px; }
    .search-input-wrap {
      position: relative; margin-bottom: 16px;
      padding: 0 20px; flex-shrink: 0;
      border-bottom: 1px solid var(--border);
      padding-bottom: 14px;
    }
    .search-input {
      width: 100%; padding: 10px 16px 10px 40px;
      background: var(--panel); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text);
      font-family: inherit; font-size: 14px; outline: none;
      transition: border-color 0.15s;
    }
    .search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(167,139,250,0.12); }
    .search-icon { position: absolute; left: 32px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
    .search-wrap-inner { display: flex; flex-direction: column; flex: 1; overflow: hidden; }

    .filter-section { margin-bottom: 18px; }
    .filter-title { font-size: 11px; font-family: var(--font-mono); letter-spacing: 1px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
    .filter-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip {
      padding: 4px 10px; border-radius: 20px; font-size: 12px;
      border: 1px solid var(--border); background: var(--panel);
      cursor: pointer; transition: all 0.15s; color: var(--text-muted);
      font-family: var(--font-mono);
    }
    .chip:hover { border-color: var(--accent); color: var(--accent); }
    .chip.active { background: rgba(167,139,250,0.15); border-color: var(--accent); color: var(--accent); }
    .chip-count { opacity: 0.6; margin-left: 4px; }

    /* Search results header: count + active place filter + did-you-mean note */
    .results-header { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; min-height: 26px; }
    .results-count { font-family: var(--font-mono); font-size: 13px; color: var(--text); font-weight: 500; }
    .results-note { font-size: 12px; color: var(--text-muted); }
    .results-note b { color: var(--accent); font-weight: 500; }
    .active-filter {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--font-mono); font-size: 12px;
      padding: 4px 6px 4px 11px; border-radius: 20px;
      background: rgba(167,139,250,0.15); border: 1px solid var(--accent); color: var(--accent);
    }
    .active-filter button { background: none; border: none; color: inherit; cursor: pointer; font-size: 12px; line-height: 1; padding: 2px 4px; border-radius: 50%; }
    .active-filter button:hover { background: rgba(167,139,250,0.25); }
    /* Spinner shown in the search box while a query is running */
    .search-icon.busy { animation: spin 0.7s linear infinite; color: var(--accent); }
    @keyframes spin { to { transform: translateY(-50%) rotate(360deg); } }

    /* Committed search-term chips that accumulate under the search bar (each Enter
       adds one; all are ANDed). */
    .search-chips { display: flex; flex-wrap: wrap; gap: 6px; padding: 0 20px; margin-bottom: 12px; }
    .search-chips:empty { display: none; }
    .search-term-chip {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 8px 5px 12px; border-radius: 999px;
      background: rgba(167,139,250,0.16); border: 1px solid var(--accent);
      color: var(--text); font-size: 13px; line-height: 1; white-space: nowrap;
    }
    .search-term-chip button {
      display: inline-flex; align-items: center; justify-content: center;
      width: 16px; height: 16px; border-radius: 50%; border: none;
      background: rgba(255,255,255,0.12); color: var(--text-muted);
      font-size: 11px; cursor: pointer; padding: 0;
    }
    .search-term-chip button:hover { background: rgba(255,255,255,0.25); color: var(--text); }

    /* ── ALBUMS SCREEN ── */
    .albums-content { flex: 1; overflow-y: auto; padding: 20px; }
    .albums-section-title {
      font-size: 11px; font-family: var(--font-mono); letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--text-muted); margin-bottom: 14px;
    }
    .smart-albums { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; margin-bottom: 32px; }
    .smart-album {
      background: var(--panel); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 18px; cursor: pointer;
      transition: all 0.2s; display: flex; align-items: center; gap: 14px;
    }
    .smart-album:hover { background: var(--panel-hover); border-color: var(--border-strong); transform: translateY(-1px); }
    .album-icon {
      width: 44px; height: 44px; border-radius: 10px; flex-shrink: 0;
      background: rgba(167,139,250,0.15); display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .album-icon.sky { background: rgba(125,211,252,0.15); }
    .album-icon.orchid { background: rgba(240,171,252,0.15); }
    .album-name { font-weight: 500; font-size: 14px; }
    .album-count { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-top: 2px; }

    .events-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    .event-card {
      border-radius: var(--radius); overflow: hidden; cursor: pointer;
      position: relative; aspect-ratio: 1;
      background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .event-card:hover { transform: scale(1.02); box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
    .event-card img { width: 100%; height: 100%; object-fit: cover; }
    .event-card-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 55%);
      display: flex; flex-direction: column; justify-content: flex-end; padding: 12px;
    }
    .event-month { font-family: var(--font-mono); font-size: 10px; color: var(--accent); letter-spacing: 1px; text-transform: uppercase; }
    .event-count { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); margin-top: 2px; }

    /* ── IMPORT SCREEN ── */
    .import-content { flex: 1; overflow-y: auto; padding: 24px; max-width: 700px; margin: 0 auto; width: 100%; }
    /* Settings screen */
    .settings-content { flex: 1; overflow-y: auto; padding: 24px; max-width: 920px; margin: 0 auto; width: 100%; }
    .settings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; margin-bottom: 20px; }
    .settings-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; }
    .settings-card-title { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px; }
    .settings-row { display: flex; justify-content: space-between; gap: 12px; padding: 4px 0; font-size: 13px; }
    .settings-row > span:first-child { color: var(--text-muted); }
    .settings-val { font-family: var(--font-mono); color: var(--text); text-align: right; }
    .settings-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .settings-section-title {
      font-family: var(--font-mono); font-size: 12px; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--accent);
      margin: 26px 0 12px; padding-bottom: 7px; border-bottom: 1px solid var(--border);
    }
    .settings-content > .settings-section-title:first-child { margin-top: 4px; }
    .card-help { font-size: 12.5px; color: var(--text-muted); line-height: 1.55; margin-bottom: 14px; }
    .card-help b { color: var(--text); font-weight: 500; }
    .action-status { font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); min-height: 16px; }
    /* Inline spinner for buttons mid-action (instant "something is happening" feedback) */
    .spin-dot {
      display: inline-block; width: 11px; height: 11px; vertical-align: -1px; margin-right: 2px;
      border: 2px solid rgba(255,255,255,0.4); border-top-color: #fff; border-radius: 50%;
      animation: spin360 0.7s linear infinite;
    }
    .btn-ghost .spin-dot { border-color: rgba(167,139,250,0.4); border-top-color: var(--accent); }
    @keyframes spin360 { to { transform: rotate(360deg); } }
    .settings-toggle { display: flex; align-items: center; gap: 10px; font-size: 13px; cursor: pointer; }
    .settings-toggle input { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; flex-shrink: 0; }
    .update-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 12px; }
    .update-row input[type=text] { flex: 1; min-width: 200px; background: rgba(255,255,255,0.07); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-family: var(--font-mono); font-size: 12px; padding: 7px 10px; outline: none; }
    .update-row input[type=text]:focus { border-color: var(--accent); }
    .update-status { margin-top: 10px; font-family: var(--font-mono); font-size: 12px; padding: 8px 10px; border-radius: 6px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); display: none; }
    .update-status.visible { display: block; }
    .update-status.ok { color: #4ade80; border-color: rgba(74,222,128,0.3); }
    .update-status.err { color: #f87171; border-color: rgba(248,113,113,0.3); }
    .update-status.info { color: var(--accent); border-color: rgba(167,139,250,0.3); }
    .update-summary {
      display: flex; flex-direction: column; gap: 6px; margin-top: 8px;
      padding: 12px 14px; border-radius: 8px;
      background: rgba(255,255,255,0.03); border: 1px solid var(--border);
    }
    .update-summary.uptodate { border-color: rgba(74,222,128,0.35); background: rgba(74,222,128,0.06); }
    .update-summary.available { border-color: rgba(167,139,250,0.35); background: rgba(167,139,250,0.06); }
    .update-summary.err { border-color: rgba(248,113,113,0.3); background: rgba(248,113,113,0.05); }
    .update-status-line { font-size: 13px; color: var(--text); font-weight: 500; }
    .update-status-line .badge { display:inline-block; padding: 2px 8px; border-radius: 8px; font-family: var(--font-mono); font-size: 11px; margin-left: 8px; }
    .update-status-line .badge.new { background: rgba(167,139,250,0.15); color: var(--accent); }
    .update-status-line .badge.ok  { background: rgba(74,222,128,0.15); color: #4ade80; }
    .update-detail { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
    .update-changelog { margin-top: 12px; }
    .update-changelog summary { cursor: pointer; font-size: 12px; color: var(--text-muted); padding: 4px 0; }
    .update-changelog summary:hover { color: var(--text); }
    .changelog-body {
      max-height: 320px; overflow-y: auto;
      margin-top: 8px; padding: 12px 14px;
      font-size: 12.5px; line-height: 1.55;
      background: rgba(0,0,0,0.28); border: 1px solid var(--border);
      border-radius: 6px;
      white-space: pre-wrap; word-break: break-word;
      color: var(--text);
    }
    .changelog-body code { font-family: var(--font-mono); background: rgba(255,255,255,0.08); padding: 1px 5px; border-radius: 3px; font-size: 11.5px; }
    .changelog-body a { color: var(--accent); }
    .import-card {
      background: var(--panel); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 24px; margin-bottom: 20px;
    }
    .import-card-title { font-size: 15px; font-weight: 600; margin-bottom: 16px; }
    /* Connected shares list */
    .share-row { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); }
    .share-row:last-child { border-bottom: none; }
    .share-info { flex: 1; min-width: 0; }
    .share-source { font-family: var(--font-mono); font-size: 12px; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .share-path { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .share-badge { font-family: var(--font-mono); font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 5px; flex-shrink: 0; }
    .share-badge-smb { background: rgba(125,211,252,0.15); color: var(--accent-sky); border: 1px solid rgba(125,211,252,0.3); }
    .share-badge-nfs { background: rgba(167,139,250,0.15); color: #a78bfa; border: 1px solid rgba(167,139,250,0.3); }
    .share-badge-sshfs, .share-badge-unknown { background: rgba(255,255,255,0.08); color: var(--text-muted); border: 1px solid var(--border); }
    .share-row .btn { font-size: 11px; flex-shrink: 0; }
    .path-input-row { display: flex; gap: 10px; }
    .path-input {
      flex: 1; padding: 10px 14px;
      background: rgba(255,255,255,0.04); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text);
      font-family: var(--font-mono); font-size: 13px; outline: none;
      transition: border-color 0.15s;
    }
    .path-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(167,139,250,0.12); }

    .pipeline-stages { display: flex; flex-direction: column; gap: 10px; margin: 16px 0; }
    .stage {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 16px; border-radius: var(--radius-sm);
      background: rgba(255,255,255,0.03); border: 1px solid var(--border);
    }
    .stage-icon { font-size: 16px; width: 24px; text-align: center; }
    .stage-name { font-weight: 500; font-size: 13px; flex: 1; }
    .stage-status { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
    .stage.active { border-color: var(--accent); background: rgba(167,139,250,0.06); }
    .stage.active .stage-status { color: var(--accent); }
    .stage.done { border-color: rgba(125,211,252,0.3); }
    .stage.done .stage-status { color: var(--accent-sky); }

    .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin: 16px 0; }
    .kpi {
      background: rgba(255,255,255,0.03); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 12px 14px;
    }
    .kpi-val { font-family: var(--font-mono); font-size: 20px; font-weight: 500; color: var(--text); }
    .kpi-label { font-size: 11px; color: var(--text-muted); margin-top: 3px; }

    .progress-bar-wrap { background: rgba(255,255,255,0.06); border-radius: 3px; height: 6px; margin: 12px 0; overflow: hidden; }
    .progress-bar { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--accent), var(--accent-sky)); transition: width 0.3s; }

    .import-field-row { display: flex; gap: 10px; flex-wrap: wrap; }
    .import-field { display: flex; flex-direction: column; gap: 5px; flex: 1; min-width: 160px; }
    .field-label { font-size: 11px; font-family: var(--font-mono); color: var(--text-muted); letter-spacing: 0.5px; }

    .log-feed {
      background: rgba(0,0,0,0.3); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 12px 14px;
      font-family: var(--font-mono); font-size: 11px; line-height: 1.7;
      max-height: 160px; overflow-y: auto; color: var(--text-muted);
    }
    .log-line.new { color: var(--text); }
    .log-line.error { color: #f87171; }

    /* Lightbox */
    .lightbox {
      display: none; position: fixed; inset: 0; z-index: 100;
      background: #000;
      align-items: center; justify-content: center;
      touch-action: none;
    }
    .lightbox.open { display: flex; }
    .lightbox-stage {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .lightbox img, .lightbox video {
      max-width: 100vw; max-height: 100vh;
      width: 100%; height: 100%;
      object-fit: contain;            /* default: show the whole picture, no crop */
      transition: opacity 0.15s;
      user-select: none; -webkit-user-select: none;
    }
    /* Pan/zoom: we drive the transform from JS; own all touch gestures on the image */
    #lightboxImg { touch-action: none; transition: transform 0.12s ease-out, opacity 0.15s; }
    .lightbox.zoomed #lightboxImg { cursor: grab; }
    .lightbox.zoomed .lightbox-prev, .lightbox.zoomed .lightbox-next { opacity: 0; pointer-events: none; }
    .lightbox.fill img, .lightbox.fill video {
      object-fit: cover;              /* maximised: fill the screen */
    }
    /* Live Photo playback: the motion clip plays as an overlay exactly covering
       the still. The stage is a flex row, so a plain display:block video would
       otherwise sit BESIDE the photo and split the frame. */
    .lightbox-stage video.live-overlay {
      position: absolute; inset: 0; margin: auto;
      width: 100%; height: 100%; object-fit: contain;
      z-index: 2; background: transparent; pointer-events: none;
    }
    .lightbox.fill .lightbox-stage video.live-overlay { object-fit: cover; }
    /* Chrome (top bar + nav) — hidden when toggled off */
    .lightbox-chrome {
      position: absolute; top: 0; left: 0; right: 0; z-index: 3;
      transition: opacity 0.25s, transform 0.25s;
    }
    .lightbox.chrome-hidden .lightbox-chrome { opacity: 0; transform: translateY(-100%); pointer-events: none; }
    .lightbox.chrome-hidden .lightbox-nav { opacity: 0; pointer-events: none; }
    .lightbox-topbar {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 18px;
      padding-top: max(14px, env(safe-area-inset-top));
      background: linear-gradient(to bottom, rgba(0,0,0,0.7), transparent);
    }
    .lightbox-title { flex: 1; font-family: var(--font-mono); font-size: 12px; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .lb-actions { display: flex; gap: 8px; }
    .lb-btn {
      width: 38px; height: 38px; border-radius: 50%;
      background: rgba(255,255,255,0.12); border: 1px solid var(--border);
      color: var(--text); font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s; flex-shrink: 0;
    }
    .lb-btn:hover { background: rgba(255,255,255,0.22); }
    .lb-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
    .lightbox-nav {
      position: absolute; top: 50%; transform: translateY(-50%); z-index: 3;
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(255,255,255,0.10); border: 1px solid var(--border);
      color: var(--text); font-size: 22px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, opacity 0.25s;
    }
    .lightbox-nav:hover { background: rgba(255,255,255,0.2); }
    .lightbox-prev { left: 20px; }
    .lightbox-next { right: 20px; }

    /* Metadata panel */
    .meta-panel {
      position: fixed; top: 0; right: 0; bottom: 0; z-index: 110;
      width: 340px; max-width: 88vw;
      background: rgba(12,12,20,0.96); backdrop-filter: blur(20px);
      border-left: 1px solid var(--border);
      transform: translateX(100%); transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
      display: flex; flex-direction: column;
      padding-top: env(safe-area-inset-top);
    }
    .meta-panel.open { transform: translateX(0); }
    .meta-panel-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 18px; border-bottom: 1px solid var(--border);
      font-weight: 600; font-size: 15px;
    }
    .meta-panel-body { flex: 1; overflow-y: auto; padding: 16px 18px; }
    .meta-row { padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .meta-key { font-family: var(--font-mono); font-size: 10px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-faint); margin-bottom: 4px; }
    .meta-val { font-size: 13.5px; color: var(--text); word-break: break-word; }
    .meta-val.mono { font-family: var(--font-mono); font-size: 12px; }
    .meta-section-title { font-family: var(--font-mono); font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); margin: 18px 0 6px; }
    .meta-section-title:first-child { margin-top: 0; }

    /* ── Caption (info panel, read-only natural-language description) ── */
    .meta-caption { font-size: 13.5px; line-height: 1.5; color: var(--text); margin: 4px 0 10px; font-style: italic; }

    /* ── Photo captioning control panel (Settings → Manage) ── */
    .cap-last { display: flex; gap: 12px; align-items: flex-start; padding: 10px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 10px; }
    .cap-last-thumb { width: 96px; height: 96px; object-fit: cover; border-radius: 8px; background: rgba(255,255,255,0.05); flex-shrink: 0; }
    .cap-last-text { min-width: 0; }
    .cap-last-cap { font-size: 13px; line-height: 1.45; color: var(--text); }
    .cap-last-meta { font-size: 11px; color: var(--text-faint); margin-top: 6px; font-family: var(--font-mono); }
    .cap-log-title { font-family: var(--font-mono); font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); margin: 16px 0 8px; }
    .cap-log { display: flex; flex-direction: column; gap: 6px; max-height: 260px; overflow-y: auto; }
    .cap-log-row { display: flex; gap: 9px; align-items: center; font-size: 12px; }
    .cap-log-thumb { width: 34px; height: 34px; object-fit: cover; border-radius: 6px; background: rgba(255,255,255,0.05); flex-shrink: 0; }
    .cap-log-cap { flex: 1; min-width: 0; color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cap-log-cap.err { color: #f87171; }
    .cap-log-cap.skip { color: var(--text-faint); font-style: italic; }
    .cap-log-time { font-size: 10px; color: var(--text-faint); font-family: var(--font-mono); flex-shrink: 0; }
    .cap-settings { margin-top: 16px; border-top: 1px solid var(--border); padding-top: 12px; }
    .cap-settings > summary { cursor: pointer; font-size: 13px; color: var(--text-muted); user-select: none; list-style: revert; }
    .cap-settings > summary:hover { color: var(--text); }
    .cap-set-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 14px; }
    .cap-set-grid label { display: flex; flex-direction: column; gap: 5px; font-size: 12px; color: var(--text-muted); }
    @media (max-width: 640px) { .cap-set-grid { grid-template-columns: 1fr; } }

    /* ── Tags (info panel) ── */
    .meta-tags { display: flex; flex-wrap: wrap; gap: 6px; margin: 4px 0 10px; }
    .meta-tag {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 6px 4px 11px; border-radius: 20px; font-size: 12.5px;
      background: rgba(167,139,250,0.15); border: 1px solid var(--accent); color: var(--accent);
      cursor: pointer; transition: background 0.15s;
    }
    .meta-tag:hover { background: rgba(167,139,250,0.25); }
    .meta-tag .tag-x { border: none; background: none; color: inherit; cursor: pointer; font-size: 13px; line-height: 1; padding: 0 2px; border-radius: 50%; opacity: 0.7; }
    .meta-tag .tag-x:hover { opacity: 1; }
    .meta-tags-empty { font-size: 12px; color: var(--text-faint); margin: 2px 0 10px; }
    .tag-add-row { display: flex; gap: 6px; }
    .tag-add-row input {
      flex: 1; min-width: 0; background: rgba(255,255,255,0.06); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text); font-family: inherit; font-size: 13px; padding: 7px 10px; outline: none;
    }
    .tag-add-row input:focus { border-color: var(--accent); }
    .tag-add-row button {
      flex-shrink: 0; padding: 7px 14px; border-radius: 8px; border: none; cursor: pointer;
      background: var(--accent); color: #fff; font-family: inherit; font-size: 13px; font-weight: 500;
    }
    .tag-add-row button:disabled { opacity: 0.5; cursor: default; }
    /* Smart-tag suggestion card */
    .tag-suggest {
      margin-top: 12px; padding: 12px 14px; border-radius: var(--radius-sm);
      background: rgba(125,211,252,0.08); border: 1px solid rgba(125,211,252,0.35);
      font-size: 13px; line-height: 1.5; color: var(--text);
      animation: suggestIn 0.25s ease-out;
    }
    @keyframes suggestIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
    .tag-suggest b { color: var(--accent-sky); }
    .tag-suggest-actions { display: flex; gap: 8px; margin-top: 10px; }
    .tag-suggest-actions button {
      padding: 7px 14px; border-radius: 8px; border: 1px solid var(--border); cursor: pointer;
      font-family: inherit; font-size: 12.5px; font-weight: 500;
    }
    .tag-suggest-add { background: var(--accent-sky); color: var(--void); border: none; }
    .tag-suggest-dismiss { background: transparent; color: var(--text-muted); }
    .tag-suggest-dismiss:hover { color: var(--text); }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

    /* Toast */
    .toast {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
      background: rgba(30,30,40,0.95); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 10px 20px;
      font-size: 13px; z-index: 200; opacity: 0; transition: opacity 0.2s;
      pointer-events: none; backdrop-filter: blur(10px);
    }
    .toast.show { opacity: 1; }

    /* ── Mobile bottom navigation (hidden on desktop) ── */
    .bottom-nav { display: none; }

    /* ════════════ RESPONSIVE / MOBILE ════════════ */
    @media (max-width: 760px) {
      :root { --tile-size: 116px; }

      /* Hide the desktop sidebar, show the bottom tab bar */
      .sidebar { display: none; }
      .app { flex-direction: column; }
      .main { height: 100vh; height: 100dvh; }

      .bottom-nav {
        display: flex;
        position: fixed; left: 0; right: 0; bottom: 0; z-index: 60;
        background: rgba(10,10,16,0.92); backdrop-filter: blur(20px);
        border-top: 1px solid var(--border);
        padding-bottom: env(safe-area-inset-bottom);
      }
      .bnav-item {
        flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px;
        padding: 8px 0 7px; cursor: pointer; color: var(--text-faint);
        font-size: 10px; font-weight: 500; transition: color 0.15s;
      }
      .bnav-item.active { color: var(--accent); }
      .bnav-icon { font-size: 19px; }

      /* Give content room above the tab bar */
      .screen { padding-bottom: calc(56px + env(safe-area-inset-bottom)); }
      .photo-grid-wrap { padding: 10px 10px calc(60px + env(safe-area-inset-bottom)); }

      /* Topbar: tighten, allow tab group to wrap/scroll */
      .topbar { padding: 12px 14px; padding-top: max(12px, env(safe-area-inset-top)); flex-wrap: wrap; }
      .topbar-title { font-size: 17px; }
      .topbar-count { font-size: 11px; }
      .tab-group { width: 100%; margin-top: 8px; overflow-x: auto; }
      .tab-btn { flex: 1; white-space: nowrap; }

      /* Library controls: compact */
      .library-controls { padding: 10px 14px; }
      .slider-row { gap: 8px; flex-wrap: wrap; }
      .slider-label { min-width: auto; }
      .slider-value { min-width: auto; font-size: 10px; }
      .grid-density-row { display: none; }  /* pinch/density not needed on mobile */

      /* Grid gap tighter, iOS-like */
      #photoGrid .photo-tile { border-radius: 3px; }

      /* Places: stack map + detail */
      .places-layout { flex-direction: column; }
      .place-detail { width: 100%; height: 45%; border-left: none; border-top: 1px solid var(--border); }
      .map-area { min-height: 280px; }

      /* Search: collapse facet sidebar to top */
      .search-layout { flex-direction: column; }
      .search-sidebar { width: 100%; max-height: 130px; border-right: none; border-bottom: 1px solid var(--border); display: flex; gap: 16px; }
      .filter-section { margin-bottom: 0; }

      /* Import: full width */
      .import-content { padding: 14px; }
      .import-field { min-width: 100%; }
      .kpi-row { grid-template-columns: repeat(2, 1fr); }

      /* Settings: tighten padding, single-column cards, keep wide bits scrollable
         so nothing forces horizontal page scroll on a 375px screen. */
      .settings-content { padding: 14px; }
      .settings-grid { grid-template-columns: 1fr; gap: 10px; }
      .settings-card, .import-card { padding: 14px 16px; }
      .import-card { padding: 16px; }
      .settings-section-title { margin: 20px 0 10px; }
      .settings-row { flex-wrap: wrap; }
      .settings-val { text-align: left; word-break: break-word; }
      .import-field-row { flex-direction: column; gap: 8px; }
      .import-field { min-width: 100%; max-width: 100% !important; }
      .update-row { flex-direction: column; align-items: stretch; }
      .update-row input[type=text] { min-width: 0; width: 100%; }
      /* Sub-tab bar: nudge padding to fit more chips before it needs to scroll,
         and hide its scrollbar (it still swipes). */
      .settings-tabs { margin-bottom: 14px; -webkit-overflow-scrolling: touch; }
      .settings-tabs::-webkit-scrollbar { display: none; }
      .stab { padding: 9px 12px; font-size: 12.5px; }
      /* RBAC & audit tables — let the row scroll horizontally rather than
         squishing every column into unreadable widths. */
      .rbac-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .rbac-table { min-width: 480px; }
      /* Duplicate scanner thumbs — smaller so more fit per row. */
      .dup-item { width: 76px; }
      .dup-thumb { width: 68px; height: 68px; }
      /* Passcode card was a fixed 320px which is tight on 320px devices. */
      .passcode-card { padding: 24px 20px; }

      /* Albums tighter */
      .smart-albums { grid-template-columns: 1fr 1fr; }
      .events-grid { grid-template-columns: repeat(2, 1fr); }

      /* Metadata panel becomes a bottom sheet */
      .meta-panel {
        top: auto; left: 0; right: 0; bottom: 0; width: 100%; max-width: 100%;
        height: 62vh; border-left: none; border-top: 1px solid var(--border);
        border-radius: 18px 18px 0 0;
        transform: translateY(100%);
        padding-top: 0; padding-bottom: env(safe-area-inset-bottom);
      }
      .meta-panel.open { transform: translateY(0); }

      /* Bigger touch targets in lightbox; hide arrows (use swipe) */
      .lightbox-nav { display: none; }
      .lb-btn { width: 42px; height: 42px; font-size: 17px; }

      .aurora-bg span { filter: blur(80px); }  /* cheaper blur on mobile GPUs */
    }

    /* Standalone PWA: extra safe-area padding when launched from home screen.
       On iOS the frame is drawn under the notch/home indicator (we set
       apple-mobile-web-app-status-bar-style=black-translucent + viewport-fit=
       cover). Push the top bar down past the notch and lift the bottom nav
       above the home indicator so nothing important lives in the OS-reserved
       zones — but keep the app background filling those zones so they don't
       read as a white bar. */
    @media (display-mode: standalone) {
      html, body { background: var(--void); }
      .topbar { padding-top: max(14px, env(safe-area-inset-top)); }
      .bottom-nav { padding-bottom: max(6px, env(safe-area-inset-bottom)); }
    }

    /* ── Settings sub-tabs ── */
    .settings-tabs { display:flex; gap:0; border-bottom:1px solid var(--border); margin-bottom:20px; overflow-x:auto; flex-shrink:0; }
    .stab { padding:9px 15px; font-size:13px; font-weight:500; color:var(--text-muted); cursor:pointer; border:none; background:none; border-bottom:2px solid transparent; transition:all 0.15s; white-space:nowrap; font-family:inherit; }
    .stab:hover { color:var(--text); }
    .stab.active { color:var(--accent); border-bottom-color:var(--accent); }
    .stab-panel { display:none; }
    .stab-panel.active { display:block; }

    /* ── RBAC (Users, Roles, Audit) ── */
    .rbac-table { width:100%; border-collapse:collapse; margin-top:8px; font-size:13px; }
    .rbac-table th, .rbac-table td { text-align:left; padding:8px 10px; border-bottom:1px solid var(--border); vertical-align:middle; }
    .rbac-table th { color:var(--text-muted); font-weight:500; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; }
    .rbac-table td { color:var(--text); }
    .rbac-table td .muted { color:var(--text-muted); font-size:12px; }
    .rbac-table select, .rbac-table input { background:rgba(0,0,0,0.3); color:var(--text); border:1px solid var(--border); border-radius:6px; padding:5px 8px; font-family:inherit; font-size:12px; }
    .rbac-badge { display:inline-block; padding:2px 8px; border-radius:10px; font-size:11px; letter-spacing:0.5px; }
    .rbac-badge.admin { background:rgba(167,139,250,0.18); color:var(--accent); }
    .rbac-badge.user { background:rgba(125,211,252,0.15); color:var(--accent-sky); }
    .rbac-badge.custom { background:rgba(240,171,252,0.15); color:var(--accent-orchid); }
    .rbac-badge.disabled { background:rgba(248,113,113,0.15); color:#f87171; }
    .rbac-row-actions { display:flex; gap:6px; justify-content:flex-end; }
    .rbac-row-actions .btn { font-size:11px; padding:5px 10px; }
    .rbac-perm-group { margin-top:14px; }
    .rbac-perm-group h4 { font-size:11px; text-transform:uppercase; letter-spacing:0.8px; color:var(--text-muted); margin-bottom:6px; }
    .rbac-perm-list { display:grid; grid-template-columns:1fr; gap:6px; }
    .rbac-perm-list label { display:flex; align-items:flex-start; gap:8px; font-size:13px; color:var(--text); cursor:pointer; }
    .rbac-perm-list label input { margin-top:3px; accent-color:var(--accent); }
    .rbac-perm-list label span.desc { color:var(--text-muted); font-size:12px; margin-left:4px; }

    /* ── User / role dialog (reuses passcode-overlay backdrop pattern) ── */
    .rbac-dialog { background:rgba(14,14,24,0.97); border:1px solid var(--border-strong); border-radius:var(--radius); padding:24px 22px; width:min(440px, 92vw); max-height:88vh; overflow-y:auto; backdrop-filter:blur(24px); }
    .rbac-dialog h3 { font-size:16px; font-weight:600; margin-bottom:14px; }
    .rbac-dialog label.field { display:block; font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; margin:10px 0 4px; }
    .rbac-dialog input[type=text], .rbac-dialog input[type=password], .rbac-dialog select { width:100%; background:rgba(0,0,0,0.3); color:var(--text); border:1px solid var(--border); border-radius:8px; padding:9px 11px; font-family:inherit; font-size:14px; outline:none; }
    .rbac-dialog input:focus, .rbac-dialog select:focus { border-color:var(--accent); }
    .rbac-dialog .actions { display:flex; gap:8px; justify-content:flex-end; margin-top:18px; }
    .rbac-dialog .err { display:none; margin-top:10px; padding:8px 10px; background:rgba(248,113,113,0.1); border:1px solid rgba(248,113,113,0.3); border-radius:8px; color:#f87171; font-size:12px; }
    .rbac-dialog .err.show { display:block; }
    .rbac-dialog .rbac-hint { margin-top:10px; font-size:12px; color:var(--text-muted); line-height:1.45; }

    /* ── Topbar user chip ── */
    .user-chip { display:flex; align-items:center; gap:6px; padding:6px 10px; border-radius:20px; background:var(--panel); border:1px solid var(--border); font-size:12px; color:var(--text); cursor:pointer; font-family:inherit; }
    .user-chip:hover { background:var(--panel-hover); }
    .user-menu { position:absolute; right:16px; top:52px; background:rgba(14,14,24,0.97); border:1px solid var(--border-strong); border-radius:12px; padding:8px; min-width:180px; backdrop-filter:blur(24px); z-index:1000; box-shadow:0 8px 24px rgba(0,0,0,0.4); display:none; }
    .user-menu.show { display:block; }
    .user-menu .row { padding:8px 12px; border-radius:8px; cursor:pointer; font-size:13px; color:var(--text); }
    .user-menu .row:hover { background:var(--panel-hover); }
    .user-menu .row.head { color:var(--text-muted); cursor:default; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; padding-top:4px; padding-bottom:6px; }
    .user-menu .row.head:hover { background:none; }

    /* Hide anything marked perm-gated until we know it's allowed. */
    .perm-gated { display:none; }
    /* Until loadMe() runs, hide permission-gated elements so a plain user
       never sees an admin control flash into view then disappear. */
    body:not(.perms-ready) [data-perm], body:not(.perms-ready) [data-perm-any] { visibility:hidden; }

    /* ── Passcode overlay ── */
    .passcode-overlay { position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:9999;display:flex;align-items:center;justify-content:center; }
    .passcode-card { background:rgba(14,14,24,0.97);border:1px solid var(--border-strong);border-radius:var(--radius);padding:32px 28px;max-width:320px;width:90%;text-align:center;backdrop-filter:blur(24px); }
    .passcode-title { font-size:17px;font-weight:600;margin-bottom:6px; }
    .passcode-sub { font-size:13px;color:var(--text-muted);margin-bottom:16px; }
    .passcode-input { width:100%;text-align:center;letter-spacing:6px;font-size:22px;font-family:var(--font-mono);background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:12px;outline:none;margin-bottom:8px; }
    .passcode-input:focus { border-color:var(--accent); }
    .passcode-err { font-size:12px;color:#f87171;min-height:18px;margin-bottom:8px; }
    @keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-10px)} 60%{transform:translateX(10px)} 80%{transform:translateX(-6px)} }

    /* ── Duplicate groups ── */
    .dup-group { background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:10px;padding:12px 14px;margin-bottom:10px; }
    .dup-group-hdr { font-size:12px;color:var(--text-muted);margin-bottom:10px; }
    .dup-thumbs { display:flex;gap:10px;flex-wrap:wrap; }
    .dup-item { display:flex;flex-direction:column;align-items:center;gap:5px;width:90px; }
    .dup-thumb { width:80px;height:80px;object-fit:cover;border-radius:6px;cursor:pointer;border:2px solid transparent; }
    .dup-item.keep-candidate .dup-thumb { border-color:var(--accent); }
    .dup-fname { font-size:10px;color:var(--text-muted);word-break:break-all;text-align:center;line-height:1.3; }
    .dup-fsize { font-family:var(--font-mono);font-size:10px;color:var(--text-faint);text-align:center; }
    .dup-keep-btn { font-size:11px;padding:3px 8px;border-radius:5px;background:var(--accent);color:#000;border:none;cursor:pointer;font-family:inherit;font-weight:600; }
    .dup-keep-btn:hover { opacity:0.85; }

    /* ── Hidden album card style ── */
    .smart-album.album-hidden { border-color:rgba(167,139,250,0.3); }
    .smart-album.album-hidden .album-icon { background:rgba(167,139,250,0.15);color:var(--accent); }

    /* ── Hidden mode banner ── */
    .hidden-banner { display:flex;align-items:center;gap:10px;padding:8px 16px;background:rgba(167,139,250,0.12);border-bottom:1px solid rgba(167,139,250,0.2);font-size:13px;flex-shrink:0; }
    .hidden-banner-label { flex:1;color:var(--accent);font-weight:500; }

    /* ════════════════════════════════════════════════════════════════════════
       v1.5 — Liquid glass, motion, touch & responsive polish
       Grouped here (rather than scattered) so each concern is editable in one
       place. Earlier rules set the base; these refine/override.
       ════════════════════════════════════════════════════════════════════════ */

    :root {
      /* Motion easing */
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);       /* decel — entrances */
      --ease-spring: cubic-bezier(0.34, 1.4, 0.5, 1);  /* slight overshoot */
      /* Liquid-glass surface tokens. NOTE: no saturate() — the colour-matrix pass
         is the expensive part and tanks scroll perf; plain blur is cheap. */
      --glass-blur: blur(16px);
      --glass-blur-sm: blur(10px);
      --glass-edge: inset 0 1px 0 rgba(255,255,255,0.10);  /* top specular line */
    }

    /* ── Liquid glass: add -webkit- prefix (required on iOS/Safari)
       + a faint specular top-edge so surfaces read as frosted glass.
       Scroll-overlapping bars get blur stripped on mobile further down. ── */
    .sidebar, .topbar, .meta-panel, .selection-bar, .place-detail,
    .passcode-card, .bottom-nav {
      -webkit-backdrop-filter: var(--glass-blur);
      backdrop-filter: var(--glass-blur);
    }
    .library-controls, .lb-btn, .lightbox-nav, .map-ctrl, .icon-btn,
    .search-filter-toggle {
      -webkit-backdrop-filter: var(--glass-blur-sm);
      backdrop-filter: var(--glass-blur-sm);
    }
    .sidebar, .topbar, .meta-panel, .place-detail, .passcode-card,
    .bottom-nav, .tab-group, .library-controls,
    .lb-btn, .lightbox-nav, .icon-btn, .map-ctrl, .search-filter-toggle {
      box-shadow: var(--glass-edge);
    }
    .selection-bar { box-shadow: var(--glass-edge), 0 14px 44px rgba(0,0,0,0.6); }

    /* ── Apple-inspired motion ── */
    @keyframes screenIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
    .screen.active { animation: screenIn 0.34s var(--ease-out); }

    .lightbox.open { animation: lbFade 0.26s var(--ease-out); }
    @keyframes lbFade { from { opacity: 0; } to { opacity: 1; } }
    /* Stage scales up on open; the JS pan/zoom transform lives on #lightboxImg,
       not the stage, so this never fights gestures. Only fires on open (the
       .open class is already present during prev/next nav). */
    .lightbox.open .lightbox-stage { animation: lbZoomIn 0.34s var(--ease-spring); }
    @keyframes lbZoomIn { from { transform: scale(0.90); opacity: 0.35; } to { transform: none; opacity: 1; } }

    /* Tactile press feedback on anything clickable. */
    .btn:active, .btn-ghost:active, .lb-btn:active, .icon-btn:active,
    .sel-btn:active, .chip:active, .tab-btn:active, .stab:active,
    .nav-item:active, .bnav-item:active, .smart-album:active,
    .search-filter-toggle:active, .map-ctrl:active {
      transform: scale(0.95);
    }
    /* Nav arrows are centred with translateY(-50%); keep it in the press state so
       the button shrinks in place instead of dropping out from under the cursor. */
    .lightbox-nav:active { transform: translateY(-50%) scale(0.95); }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.001ms !important; animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important; scroll-behavior: auto !important;
      }
      .aurora-bg span { animation: none !important; }
    }

    /* ── Task 2: one-tap on touch devices ──
       :hover styles on a tile cause iOS to require a phantom first tap ("show
       hover") before the click. Neutralising hover on non-hover pointers makes
       the first tap open the photo. (.faved heart stays visible — not gated.) */
    @media (hover: none) {
      .photo-tile:hover { transform: none; box-shadow: none; z-index: auto; }
      .photo-tile:hover .tile-overlay { opacity: 0; }
      .photo-tile:hover .tile-fav { opacity: 0; }
    }

    /* ── Task 1: Live Photo hover preview (motion clip plays in the tile) ── */
    .tile-live-preview {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; border-radius: inherit; z-index: 1; background: #000;
      animation: lbFade 0.25s ease;
    }
    /* Keep badges/date above the playing preview. */
    .tile-live-badge, .tile-video-badge { z-index: 3; }
    .photo-tile .tile-overlay { z-index: 3; }

    /* ── Task 3: video lightbox — hide side arrows (they can sit over the
       native transport bar on letterboxed clips; swipe + ← → still navigate). ── */
    .lightbox.is-video .lightbox-nav { display: none; }

    /* ── Task 6: mobile search filters collapse behind a Filters toggle ── */
    .search-filter-toggle { display: none; }
    @media (max-width: 760px) {
      .search-filter-toggle {
        display: inline-flex; align-items: center; gap: 7px; align-self: flex-start;
        margin: 0 20px 12px; padding: 8px 15px; border-radius: 20px; flex-shrink: 0;
        background: rgba(255,255,255,0.06); border: 1px solid var(--border);
        color: var(--text); font-family: inherit; font-size: 13px; cursor: pointer;
      }
      .search-filter-toggle.open { background: rgba(167,139,250,0.15); border-color: var(--accent); color: var(--accent); }
      .search-filter-toggle .ft-count {
        display: none; min-width: 18px; height: 18px; padding: 0 5px; border-radius: 9px;
        background: var(--accent); color: #fff; font-size: 11px; font-family: var(--font-mono);
        align-items: center; justify-content: center; line-height: 1;
      }
      .search-filter-toggle.has-active .ft-count { display: inline-flex; }

      /* Override the cramped 130px horizontal strip: a tidy collapsible panel. */
      .search-sidebar {
        width: 100%; display: block; gap: 0; max-height: 0; overflow: hidden;
        padding: 0 20px; border-right: none; border-bottom: 1px solid transparent;
        transition: max-height 0.32s var(--ease-out), padding 0.28s var(--ease-out);
      }
      .search-sidebar.open {
        max-height: 60vh; overflow-y: auto; padding: 4px 20px 14px;
        border-bottom: 1px solid var(--border);
      }
      .search-sidebar .filter-section { margin-bottom: 16px; }
    }

    /* ── Task 7: map place names show clearly (readable glass label above dot,
       de-cluttered so they don't pile up). ── */
    .pin-label {
      position: absolute; left: 50%; bottom: calc(100% + 7px); top: auto;
      transform: translateX(-50%);
      font-family: var(--font-mono); font-size: 10.5px; font-weight: 500; white-space: nowrap;
      color: var(--text); background: rgba(8,8,16,0.85);
      -webkit-backdrop-filter: blur(7px); backdrop-filter: blur(7px);
      border: 1px solid var(--border-strong); border-radius: 7px; padding: 3px 9px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.5);
      opacity: 0; transition: opacity 0.15s; pointer-events: none; z-index: 6;
    }
    .place-pin:hover .pin-label, .place-pin.active .pin-label,
    .place-pin.show-label .pin-label { opacity: 1; }
    .place-pin:hover, .place-pin.active { z-index: 10; }

    /* ── Debug perf HUD (only shown when enabled) ── */
    #perfHud {
      display: none; position: fixed; top: 0; left: 0; z-index: 99999;
      font-family: var(--font-mono); font-size: 10px; line-height: 1.45;
      color: #9effa0; background: rgba(0,0,0,0.82); padding: 6px 8px;
      border-bottom-right-radius: 8px; white-space: pre; pointer-events: none;
      max-width: 60vw; letter-spacing: 0.2px;
    }
    #perfHud b { color: #fff; font-weight: 600; }
    #perfHud .warn { color: #fbbf24; }
    #perfHud .bad { color: #f87171; }

    /* Stale-build "Reload" banner */
    #updateBanner {
      position: fixed; left: 50%; transform: translateX(-50%);
      bottom: calc(18px + env(safe-area-inset-bottom)); z-index: 100000;
      display: flex; align-items: center; gap: 12px; max-width: 92vw;
      background: rgba(167,139,250,0.95); color: #1a1030;
      padding: 10px 12px 10px 16px; border-radius: 12px; font-size: 13px; font-weight: 500;
      box-shadow: 0 10px 34px rgba(0,0,0,0.5);
    }
    #updateBanner button {
      border: none; background: #1a1030; color: #fff; font-family: inherit; font-weight: 600;
      font-size: 13px; padding: 7px 14px; border-radius: 8px; cursor: pointer;
    }

    /* ── Perf: stop the date readout from reflowing the slider ──
       A variable-width readout resizes the flex row (and the slider track) every
       time the date text changes length, making the thumb jump. Pin it to a
       stable width so the slider never moves. */
    .slider-value {
      width: 132px; flex: 0 0 132px; min-width: 0;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    /* ── Perf: mobile scroll must stay buttery ──
       backdrop-filter on bars that scrolling content passes under (the fixed
       bottom-nav especially) forces a full-frame blur repaint on every scroll
       tick on mobile GPUs. Use solid bars on phones; keep the glass on desktop
       where it's cheap. (These bars don't overlap scroll on desktop anyway.) */
    @media (max-width: 760px) {
      .topbar, .library-controls, .bottom-nav, .search-filter-toggle,
      .sidebar, .meta-panel, .selection-bar {
        -webkit-backdrop-filter: none !important; backdrop-filter: none !important;
      }
      .topbar { background: rgba(8,8,14,0.94); }
      .library-controls { background: rgba(10,10,16,0.92); }
      .bottom-nav { background: rgba(8,8,14,0.96); }
      /* Static skeleton — a moving-gradient shimmer is a per-frame PAINT; with
         hundreds of search tiles that's a lot of continuous repaint on a phone. */
      .photo-tile .tile-skeleton { animation: none; background: rgba(255,255,255,0.06); }
    }
  </style>
</head>
<body>
  <div class="aurora-bg"><span></span><span></span><span></span></div>

  <!-- Debug perf HUD: hidden unless ?debug=1 (persisted). See initPerfHud(). -->
  <div id="perfHud"></div>

  <div class="app">
    <!-- Sidebar -->
    <aside class="sidebar">
      <button type="button" class="sidebar-collapse" id="sidebarCollapseBtn" onclick="toggleSidebar()" title="Collapse sidebar" aria-label="Collapse sidebar">‹</button>
      <div class="sidebar-logo">
        <div class="logo-icon">✦</div>
        <div>
          <div class="logo-text">Aurora</div>
          <div class="logo-sub">LOCAL · PHOTO</div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-item active" data-screen="library" data-tip="Library">
          <span class="nav-icon">▦</span><span class="nav-label">Library</span>
          <span class="nav-badge" id="navBadgeLibrary">—</span>
        </div>
        <div class="nav-item" data-screen="places" data-tip="Places">
          <span class="nav-icon">◎</span><span class="nav-label">Places</span>
          <span class="nav-badge" id="navBadgePlaces">—</span>
        </div>
        <div class="nav-item" data-screen="search" data-tip="Search">
          <span class="nav-icon">⌕</span><span class="nav-label">Search</span>
        </div>
        <div class="nav-item" data-screen="albums" data-tip="Albums">
          <span class="nav-icon">⊞</span><span class="nav-label">Albums</span>
        </div>
        <div class="nav-section" data-perm-any="settings.view users.manage audit.view photos.hidden">System</div>
        <div class="nav-item" data-screen="settings" data-perm-any="settings.view users.manage audit.view photos.hidden" data-tip="Settings &amp; Import">
          <span class="nav-icon">⚙</span><span class="nav-label">Settings &amp; Import</span>
        </div>
      </nav>

      <div class="sidebar-stats" id="sidebarStats">
        <div class="stat-row"><span class="stat-label">Photos</span><span class="stat-val" id="statPhotos">—</span></div>
        <div class="stat-row"><span class="stat-label">Videos</span><span class="stat-val" id="statVideos">—</span></div>
        <div class="stat-row"><span class="stat-label">Places</span><span class="stat-val" id="statPlaces">—</span></div>
        <div class="stat-row"><span class="stat-label">Storage</span><span class="stat-val" id="statStorage">—</span></div>
      </div>
    </aside>

    <!-- Main -->
    <main class="main">

      <!-- LIBRARY -->
      <div class="screen active" id="screen-library">
        <div class="topbar">
          <span class="topbar-title">Library</span>
          <span class="topbar-count" id="libraryCount">— items</span>
          <div class="topbar-spacer"></div>
          <div class="tab-group">
            <button class="tab-btn active" data-filter="all">All</button>
            <button class="tab-btn" data-filter="photo">Photos</button>
            <button class="tab-btn" data-filter="video">Videos</button>
            <button class="tab-btn" data-filter="fav">Favorites</button>
          </div>
          <button class="btn btn-ghost" id="libSelectBtn" data-perm-any="photos.tag photos.download photos.hidden" style="font-size:12px;margin-left:8px;" onclick="toggleSelectMode()">Select</button>
        </div>
        <div class="library-controls">
          <div class="slider-row">
            <span class="slider-label">Time range</span>
            <div class="range-wrap" style="flex-direction: column; gap: 4px; align-items: stretch; height: auto;">
              <div class="histogram" id="histogram"></div>
              <div style="display:flex; gap:8px;">
                <input type="range" id="timeFrom" min="0" max="100" value="0">
                <input type="range" id="timeTo" min="0" max="100" value="100">
              </div>
            </div>
            <span class="slider-value" id="timeRangeLabel">All time</span>
          </div>
          <div class="grid-density-row">
            <span class="density-label">Grid size</span>
            <input type="range" id="densitySlider" min="80" max="280" value="180" step="20">
            <span class="density-label" style="margin-left:8px;" id="densityVal">180px</span>
          </div>
        </div>
        <div class="photo-grid-wrap" id="photoGridWrap">
          <div class="empty-state" id="libraryLoading">
            <div class="empty-icon" style="animation:spin 1s linear infinite;display:inline-block;">◌</div>
          </div>
          <div class="empty-state" id="libraryEmpty" style="display:none;">
            <div class="empty-icon">✦</div>
            <div class="empty-title">No photos yet</div>
            <div class="empty-desc">Import a folder to start building your library. Aurora indexes metadata without touching your originals.</div>
            <button class="btn" onclick="switchScreen('settings')">Import photos</button>
          </div>
          <div class="floating-month" id="floatingMonth"></div>
          <div id="photoGrid"></div>
        </div>
      </div>

      <!-- PLACES -->
      <div class="screen" id="screen-places">
        <div class="topbar">
          <span class="topbar-title">Places</span>
          <span class="topbar-count" id="placesCount">— locations</span>
        </div>
        <div class="places-layout">
          <div class="map-area" id="mapArea">
            <div class="map-placeholder" id="mapPlaceholder">
              <div style="font-size:40px;opacity:0.2">◎</div>
              <div style="font-size:13px;color:var(--text-muted)">No geotagged photos yet</div>
            </div>
            <svg class="world-map" id="worldMap" preserveAspectRatio="xMidYMid meet"></svg>
            <div class="map-labels" id="mapLabels"></div>
            <div class="place-pins" id="placePins"></div>
            <div class="map-controls">
              <button class="map-ctrl" onclick="mapZoomBtn(1)" title="Zoom in">+</button>
              <button class="map-ctrl" onclick="mapZoomBtn(-1)" title="Zoom out">−</button>
              <button class="map-ctrl" onclick="resetMapView()" title="Reset view">⌂</button>
            </div>
            <div class="map-hint">Scroll or pinch to zoom · drag to pan</div>
          </div>
          <div class="place-detail" id="placeDetail" style="display:none;">
            <div class="place-detail-header">
              <div class="place-detail-name" id="placeDetailName">—</div>
              <div class="place-detail-meta" id="placeDetailMeta">—</div>
              <button class="btn" id="placeViewAllBtn" style="margin-top:12px;width:100%;font-size:13px;" onclick="placeViewAll()" disabled>View all photos →</button>
            </div>
            <div class="place-detail-preview-label">Preview</div>
            <div class="place-mini-grid" id="placeDetailGrid"></div>
          </div>
        </div>
      </div>

      <!-- SEARCH -->
      <div class="screen" id="screen-search">
        <div class="topbar">
          <span class="topbar-title">Search</span>
          <span class="topbar-count" id="searchCount"></span>
          <div class="topbar-spacer"></div>
          <button class="btn btn-ghost" id="searchSelectBtn" data-perm-any="photos.tag photos.download photos.hidden" style="font-size:12px;" onclick="toggleSelectMode()">Select</button>
        </div>
        <div class="search-wrap-inner">
          <div class="search-input-wrap" style="padding-top:14px;">
            <span class="search-icon" id="searchIcon">⌕</span>
            <input type="text" class="search-input" id="searchInput" placeholder="Search — places, dates, tags, or describe a photo (e.g. girl holding a coffee)">
          </div>
          <div class="search-chips" id="searchChips"></div>
          <button class="search-filter-toggle" id="searchFilterToggle" onclick="toggleSearchFilters()">⚙ Filters <span class="ft-count" id="searchFilterCount">0</span></button>
          <div class="search-layout">
            <div class="search-sidebar">
              <div class="filter-section">
                <div class="filter-title">Show</div>
                <div class="filter-chips">
                  <span class="chip active" data-search-filter="kind" data-val="">All</span>
                  <span class="chip" data-search-filter="kind" data-val="photo">Photos</span>
                  <span class="chip" data-search-filter="kind" data-val="video">Videos</span>
                  <span class="chip" id="favChip" onclick="toggleFavFilter(this)">★ Favourites</span>
                </div>
              </div>
              <div class="filter-section">
                <div class="filter-title">Cameras</div>
                <div class="filter-chips" id="cameraChips">
                  <span style="font-size:11px;color:var(--text-faint)">Loading…</span>
                </div>
              </div>
              <div class="filter-section">
                <div class="filter-title">Countries</div>
                <div class="filter-chips" id="countryChips">
                  <span style="font-size:11px;color:var(--text-faint)">Loading…</span>
                </div>
              </div>
              <div class="filter-section" id="tagFilterSection" style="display:none;">
                <div class="filter-title">Tags</div>
                <div class="filter-chips" id="tagChips"></div>
              </div>
            </div>
            <!-- Hidden album banner (shown when browsing hidden photos) -->
            <div class="hidden-banner" id="hiddenBanner" style="display:none;">
              <span class="hidden-banner-label">🔒 Hidden Photos</span>
              <button class="btn btn-ghost" style="font-size:12px;" onclick="exitHiddenMode()">Exit ✕</button>
            </div>

            <div class="search-results" id="searchResults">
              <div class="results-header" id="searchHeader" style="display:none;">
                <span class="results-count" id="searchResultsCount">—</span>
                <span class="active-filter" id="searchPlaceFilter" style="display:none;">
                  <span id="searchPlaceFilterName"></span>
                  <button onclick="clearSearchPlace()" title="Clear place filter">✕</button>
                </span>
                <span class="results-note" id="searchCorrected"></span>
              </div>
              <div class="photo-grid" id="searchGrid"></div>
              <div class="empty-state" id="searchEmpty" style="display:none;">
                <div class="empty-icon">⌕</div>
                <div class="empty-title">No results</div>
                <div class="empty-desc">Try fewer or different words — search matches places, cameras, years, and file names, and tolerates typos.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ALBUMS -->
      <div class="screen" id="screen-albums">
        <div class="topbar">
          <span class="topbar-title">Albums</span>
        </div>
        <div class="albums-content">
          <div class="albums-section-title">Smart Albums</div>
          <div class="smart-albums" id="smartAlbums"></div>
          <div class="albums-section-title">Memories by Month</div>
          <div class="events-grid" id="eventsGrid"></div>
        </div>
      </div>

      <!-- SETTINGS -->
      <div class="screen" id="screen-settings">
        <div class="topbar">
          <span class="topbar-title">Settings</span>
          <span class="topbar-count" id="settingsVersionTag"></span>
          <div class="topbar-spacer"></div>
          <button class="btn btn-ghost" id="settingsRefreshBtn" style="font-size:12px;" onclick="loadSettings(this)">↻ Refresh</button>
        </div>
        <div class="settings-content">

          <!-- Sub-tab bar -->
          <div class="settings-tabs">
            <button class="stab active" data-stab="library" data-perm="settings.view" onclick="switchSettingsTab(this)">Library</button>
            <button class="stab" data-stab="import" data-perm="settings.manage" onclick="switchSettingsTab(this)">Import</button>
            <button class="stab" data-stab="manage" data-perm="settings.manage" onclick="switchSettingsTab(this)">Manage</button>
            <button class="stab" data-stab="privacy" data-perm="photos.hidden" onclick="switchSettingsTab(this)">Privacy</button>
            <button class="stab" data-stab="duplicates" data-perm="settings.view" onclick="switchSettingsTab(this)">Duplicates</button>
            <button class="stab" data-stab="system" data-perm="settings.manage" onclick="switchSettingsTab(this)">System</button>
            <button class="stab admin-only" data-stab="users" onclick="switchSettingsTab(this)" style="display:none;">Users &amp; roles</button>
            <button class="stab admin-only" data-stab="audit" onclick="switchSettingsTab(this)" style="display:none;">Audit log</button>
          </div>

          <!-- ── LIBRARY TAB ── -->
          <div class="stab-panel active" id="stab-library">
            <div class="settings-grid" id="settingsMetrics">
              <div style="color:var(--text-faint);font-size:13px;">Loading metrics…</div>
            </div>
            <div class="settings-section-title" style="margin-top:20px;">Display</div>
            <div class="import-card">
              <div class="import-card-title">Options</div>
              <label class="settings-toggle">
                <input type="checkbox" id="toggleHideRaw" onchange="setHideRaw(this.checked)">
                <span>Hide RAW photos <span style="color:var(--text-muted)">(.cr2 / .nef / .arw / .dng — can't be previewed in a browser)</span></span>
              </label>
            </div>
          </div>

          <!-- ── IMPORT TAB ── -->
          <div class="stab-panel" id="stab-import">
            <div class="import-card">
              <div class="import-card-title">Add a source</div>
              <div class="card-help">Connect a network share or point at a folder on the server. Aurora mounts it <b>read-only</b> — your original files are never modified.</div>

              <div class="tab-group" style="margin-bottom:16px;width:fit-content;">
                <button class="tab-btn active" data-proto="smb" onclick="setProto('smb',this)">SMB / Windows</button>
                <button class="tab-btn" data-proto="nfs" onclick="setProto('nfs',this)">NFS</button>
                <button class="tab-btn" data-proto="local" onclick="setProto('local',this)">Local path</button>
              </div>

              <div id="proto-smb">
                <div class="import-field-row">
                  <div class="import-field">
                    <label class="field-label">Host / IP</label>
                    <input type="text" class="path-input" id="smbHost" placeholder="192.168.1.50">
                  </div>
                  <div class="import-field">
                    <label class="field-label">Share name</label>
                    <input type="text" class="path-input" id="smbShare" placeholder="Photos">
                  </div>
                </div>
                <div class="import-field-row" style="margin-top:10px;">
                  <div class="import-field">
                    <label class="field-label">Username <span style="color:var(--text-faint)">(optional)</span></label>
                    <input type="text" class="path-input" id="smbUser" placeholder="guest" autocomplete="off">
                  </div>
                  <div class="import-field">
                    <label class="field-label">Password <span style="color:var(--text-faint)">(optional)</span></label>
                    <input type="password" class="path-input" id="smbPass" autocomplete="off">
                  </div>
                  <div class="import-field" style="max-width:140px;">
                    <label class="field-label">Domain <span style="color:var(--text-faint)">(optional)</span></label>
                    <input type="text" class="path-input" id="smbDomain" placeholder="WORKGROUP">
                  </div>
                </div>
              </div>

              <div id="proto-nfs" style="display:none;">
                <div class="import-field-row">
                  <div class="import-field">
                    <label class="field-label">Host / IP</label>
                    <input type="text" class="path-input" id="nfsHost" placeholder="192.168.1.50">
                  </div>
                  <div class="import-field">
                    <label class="field-label">Export path</label>
                    <input type="text" class="path-input" id="nfsExport" placeholder="/export/photos">
                  </div>
                </div>
              </div>

              <div id="proto-local" style="display:none;">
                <div class="import-field-row">
                  <div class="import-field">
                    <label class="field-label">Server-local path</label>
                    <input type="text" class="path-input" id="localPath" placeholder="/mnt/photos">
                  </div>
                </div>
              </div>

              <div style="margin-top:16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
                <button class="btn" id="mountBtn" onclick="doMount()">Connect &amp; Mount</button>
                <div id="mountStatus" class="action-status"></div>
              </div>
              <div class="card-help" style="margin-top:10px;">🔒 Connected shares are remembered and re-mounted automatically after a reboot (credentials are stored in a root-only file, never in the database). Re-connecting a share you've imported before re-links to your existing photos — no need to re-import.</div>
            </div>

            <div class="import-card" id="connectedSharesCard" style="display:none;">
              <div class="import-card-title">Connected shares</div>
